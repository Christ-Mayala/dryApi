NODE_ENV=development
PORT=5000
APP_NAME=DRY API
FRONTEND_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:4200
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4200,http://localhost:5000

# Auth / Sessions
JWT_EXPIRE=7d
JWT_SECRET=replace_with_a_64_character_random_secret
JWT_SECRET_PREVIOUS=
SESSION_SECRET=replace_with_another_64_character_random_secret
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=2
LOG_REQUESTS=true

# Rate limit
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=150
RATE_LIMIT_AUTH_MULTIPLIER=100
RATE_LIMIT_ADMIN_MULTIPLIER=250
RATE_LIMIT_SKIP_AUTHENTICATED=true
RATE_LIMIT_SKIP_ADMIN=false

# Database
MONGO_URI=mongodb://127.0.0.1:27017/dryapi
MONGO_DB_PREFIX=

# Cache
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Maintenance
PURGE_ENABLED=true
PURGE_AFTER_DAYS=14
PURGE_CRON=0 3 * * *

# Seed data
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PASSWORD=ChangeMe123!

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email / OAuth
EMAIL_PROVIDER=mock
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=

# SMTP aliases
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_FROM="DRY API <no-reply@example.com>"
FROM_EMAIL=no-reply@example.com

# External providers
RESEND_API_KEY=

# SCIM
SCIM_CONTACT_EMAIL=contact@example.com
SCIM_TIMEZONE=Africa/Brazzaville
SCIM_TZ_OFFSET_MINUTES=60
SCIM_WHATSAPP_PHONE=
SCIM_ADMIN_WHATSAPP_PHONE=
SCIM_RESERVATION_SLA_MINUTES=30
SCIM_RESERVATION_REMINDER_MINUTES=30
SCIM_REMINDER_ENABLED=true
SCIM_REMINDER_CRON=*/5 * * * *
SCIM_REMINDER_BATCH_SIZE=50
SCIM_ENABLE_EMAIL_NOTIFICATIONS=false
SCIM_ENABLE_SMS_NOTIFICATIONS=false
SCIM_ENABLE_WHATSAPP_NOTIFICATIONS=false
SCIM_ENABLE_ADMIN_WHATSAPP_NOTIFICATIONS=false
SCIM_DEFAULT_COUNTRY_CODE=+242
SCIM_TWILIO_ACCOUNT_SID=
SCIM_TWILIO_AUTH_TOKEN=
SCIM_TWILIO_SMS_FROM=
SCIM_TWILIO_WHATSAPP_FROM=

# Monitoring
VIEW_IP_SALT=replace_with_a_random_tracking_salt
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
ALERT_EMAIL_TO=
HEALTH_MONITOR_INTERVAL_MS=60000
MONITOR_REPEAT_ALERTS=false
MONITOR_REPEAT_ALERT_MS=900000
MONITOR_DAILY_SUMMARY=true
MONITOR_DAILY_SUMMARY_MS=86400000
MONITOR_LOGS_EVERY_DAYS=3
MONITOR_LOGS_EVERY_MS=259200000
MONITOR_SUMMARY_ON_START=true
CRASH_ON_UNHANDLED_REJECTION=false
FATAL_ERROR_EXIT_DELAY_MS=3500

# Media
MEDIA_DIR=downloads
MEDIA_VERBOSE=false
FFMPEG_PATH=
YT_COOKIE=
YT_USER_AGENT=
YTDL_NO_UPDATE=
