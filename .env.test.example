# Config dédiée aux tests d'intégration/e2e/smoke — copier en .env.test
# et adapter MONGO_URI vers une base ISOLÉE (MongoDB local ou cluster de test),
# jamais le cluster de production. Sans ce fichier, les scripts de test
# retombent sur .env (production) avec un avertissement — voir
# scripts/tests/loadTestEnv.js et docs/04_TESTING_GUIDE.md.

NODE_ENV=test
PORT=5099
SERVER_URL=http://127.0.0.1:5099
APP_NAME=DRY API (test)

# Base de données isolée — ex: MongoDB local, ou un cluster/projet Atlas séparé
MONGO_URI=mongodb://127.0.0.1:27017/dryapi_test
MONGO_DB_PREFIX=test_

# Secrets — valeurs factices suffisantes pour les tests (pas besoin de vrais secrets)
JWT_SECRET=test_jwt_secret_64_caracteres_minimum_ceci_est_suffisant_pour_les_tests
JWT_REFRESH_SECRET=test_jwt_refresh_secret_64_caracteres_minimum_ceci_est_suffisant
SESSION_SECRET=test_session_secret_64_caracteres_minimum_ceci_est_suffisant_pour

SEED_ADMIN_EMAIL=admin@test.local
SEED_ADMIN_NAME=Admin Test
SEED_ADMIN_PASSWORD=Test123!

# Désactiver les intégrations externes réelles pendant les tests
EMAIL_PROVIDER=mock
REDIS_ENABLED=false
SCIM_ENABLE_EMAIL_NOTIFICATIONS=false
SCIM_ENABLE_SMS_NOTIFICATIONS=false
SCIM_ENABLE_WHATSAPP_NOTIFICATIONS=false
SCIM_ENABLE_ADMIN_WHATSAPP_NOTIFICATIONS=false
