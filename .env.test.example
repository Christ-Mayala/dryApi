# Config dédiée aux tests d'intégration/e2e/smoke — copier en .env.test
#
# Le framework a un mécanisme intégré de résolution de config par environnement
# (voir config/database.js -> readSetting) : quand NODE_ENV=test, chaque clé
# est d'abord cherchée sous la forme NOM_TEST (ex: MONGO_URI_TEST), puis NOM
# en dev, sinon une valeur de repli. C'est pour ça que les clés ci-dessous sont
# suffixées _TEST — c'est la même convention que .github/workflows/ci.yml.
#
# Sans .env.test, les scripts de test (scripts/tests/loadTestEnv.js) retombent
# sur .env — c'est-à-dire la config de PRODUCTION. Ne jamais pointer MONGO_URI_TEST
# vers le cluster de production. Voir docs/04_TESTING_GUIDE.md.

NODE_ENV=test
PORT_TEST=5099
SERVER_URL_TEST=http://127.0.0.1:5099
APP_NAME_TEST=DRY API (test)

# Base de données isolée — ex: MongoDB local, ou un cluster/projet Atlas séparé
MONGO_URI_TEST=mongodb://127.0.0.1:27017/dryapi_test
MONGO_DB_PREFIX_TEST=test_

# Secrets — valeurs factices suffisantes pour les tests (pas besoin de vrais secrets)
JWT_SECRET_TEST=test_jwt_secret_64_caracteres_minimum_ceci_est_suffisant_pour_les_tests
JWT_REFRESH_SECRET_TEST=test_jwt_refresh_secret_64_caracteres_minimum_ceci_est_suffisant
SESSION_SECRET_TEST=test_session_secret_64_caracteres_minimum_ceci_est_suffisant_pour

SEED_ADMIN_EMAIL_TEST=admin@test.local
SEED_ADMIN_NAME_TEST=Admin Test
SEED_ADMIN_PASSWORD_TEST=Test123!

# Désactiver les intégrations externes réelles pendant les tests
EMAIL_PROVIDER_TEST=mock
REDIS_ENABLED_TEST=false
SCIM_ENABLE_EMAIL_NOTIFICATIONS_TEST=false
SCIM_ENABLE_SMS_NOTIFICATIONS_TEST=false
SCIM_ENABLE_WHATSAPP_NOTIFICATIONS_TEST=false
SCIM_ENABLE_ADMIN_WHATSAPP_NOTIFICATIONS_TEST=false
